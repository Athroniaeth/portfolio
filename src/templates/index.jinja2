<!DOCTYPE html>
<html lang="{{ lang }}">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="description"
              content="Portfolio of {{ config.first_name }} {{ config.last_name }}, {{ config.profession }} on {{ config.address }}">
        <meta name="keywords"
              content="{{ config.profession }}, {{ config.first_name }}, {{ config.last_name }}">
        <meta name="author"
              content="{{ config.first_name }} {{ config.last_name }}">
        <title>Portfolio {{ config.first_name }} {{ config.last_name }}</title>
        <link href="{{ url_for('static', path='output.css') }}" rel="stylesheet">
        <link href="{{ url_for('static', path='anchor.css') }}" rel="stylesheet">
        <style>html { scroll-behavior: smooth;}
    </style>
    </head>
    <body>
        <header>
            {% include 'components/header.jinja2' %}
        </header>
        <main>
            {% with about=locale.about, anchor="about" %}
                {% include 'components/about.jinja2' %}
            {% endwith %}
            {% with portfolio=locale.portfolio, anchor="portfolio" %}
                {% include 'components/portfolio.jinja2' %}
            {% endwith %}
            {% with histories=locale.experience, anchor="experience" %}
                {% include 'components/histories.jinja2' %}
            {% endwith %}
            {% with histories=locale.education, anchor="education" %}
                {% include 'components/histories.jinja2' %}
            {% endwith %}
            {% with contact=locale.contact, anchor="contact" %}
                {% include 'components/contact.jinja2' %}
            {% endwith %}
        </main>
        <footer>
            {% include 'components/footer.jinja2' %}
        </footer>
        <script src="https://cdn.jsdelivr.net/npm/tailgrids@2.2.2/plugin.min.js"></script>
        <script defer
                src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    </body>
</html>
