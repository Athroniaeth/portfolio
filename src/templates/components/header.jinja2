<!-- ====== Navbar Section Start -->
<header
        x-data="
   {
   navbarOpen: false,
   }
   "
        class="absolute left-0 top-0 z-20 w-full"
>
    <div class="container mx-auto">
        <div class="relative z-10 -mx-4 flex items-center justify-between">
            <div class="w-60 max-w-full px-4">
                <a href="javascript:void(0)" class="block w-full py-5">
                    <img
                            src="{{ url_for('static', path='images/logo.svg') }}"
                            alt="logo"
                            class="w-full block "
                    />
                    <img
                            src="https://cdn.tailgrids.com/2.0/image/assets/images/logo/logo-white.svg"
                            alt="logo"
                            class="w-full hidden "
                    />
                </a>
            </div>
            <div class="flex w-full items-center justify-between px-4">
                <div>
                    <button
                            @click="navbarOpen = !navbarOpen"
                            :class="navbarOpen && 'navbarTogglerActive'"
                            id="navbarToggler"
                            class="absolute right-4 top-1/2 block -translate-y-1/2 rounded-lg px-3 py-[6px] ring-primary focus:ring-2 lg:hidden"
                    >
               <span
                       class="relative my-[6px] block h-[2px] w-[30px] bg-body-color "
               ></span>
                        <span
                                class="relative my-[6px] block h-[2px] w-[30px] bg-body-color "
                        ></span>
                        <span
                                class="relative my-[6px] block h-[2px] w-[30px] bg-body-color "
                        ></span>
                    </button>
                    <nav
                            :class="!navbarOpen && 'hidden' "
                            id="navbarCollapse"
                            class="absolute right-4 top-full z-10 w-full max-w-[250px] rounded-lg bg-white py-5 px-6 shadow lg:static lg:block lg:w-full lg:max-w-full lg:bg-transparent lg:dark:bg-transparent lg:shadow-none xl:ml-11"
                    >
                        <ul class="block lg:flex">
                            <li>
                                <a
                                        href="#home"
                                        class="flex py-2 text-base font-medium text-dark hover:text-primary lg:ml-10 lg:inline-flex"
                                >
                                    {{ locale.header.link_home }}
                                </a>
                            </li>
                            <li>
                                <a
                                        href="#about"
                                        class="flex py-2 text-base font-medium text-dark hover:text-primary lg:ml-10 lg:inline-flex"
                                >
                                    {{ locale.header.link_about }}
                                </a>
                            </li>
                            <li>
                                <a
                                        href="#portfolio"
                                        class="flex py-2 text-base font-medium text-dark hover:text-primary lg:ml-10 lg:inline-flex"
                                >
                                    {{ locale.header.link_portfolio }}
                                </a>
                            </li>
                            <li>
                                <a
                                        href="#experience"
                                        class="flex py-2 text-base font-medium text-dark hover:text-primary lg:ml-10 lg:inline-flex"
                                >
                                    {{ locale.header.link_experience }}
                                </a>
                            </li>
                            <li>
                                <a
                                        href="#education"
                                        class="flex py-2 text-base font-medium text-dark hover:text-primary lg:ml-10 lg:inline-flex"
                                >
                                    {{ locale.header.link_education }}
                                </a>
                            </li>
                            <li>
                                <a
                                        href="#contact"
                                        class="flex py-2 text-base font-medium text-dark hover:text-primary lg:ml-10 lg:inline-flex"
                                >
                                    {{ locale.header.link_contact }}
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>
                <div class="hidden justify-end pr-16 sm:flex lg:pr-0">
                    <a
                            href="javascript:void(0)"
                            class="rounded-md bg-primary py-3 px-7 text-base font-medium text-white hover:bg-blue-dark"
                    >
                        {{ locale.header.button_contact }}
                    </a>
                </div>
            </div>
        </div>
    </div>
</header>
<!-- ====== Navbar Section End -->
<!-- ====== Hero Section Start -->
<div
        x-data="
   {
   navbarOpen: false
   }
   "
        class="relative overflow-hidden z-10 bg-white pt-[120px] pb-[110px] md:pt-[150px] lg:pt-[180px]"
>
    <div class="container mx-auto">
        <div class="-mx-4 flex flex-wrap">
            <div class="w-full px-4 lg:w-5/12">
                <div class="hero-content">
               <span
                       class="mb-4 inline-block rounded-[30px] rounded-tl-[20px] rounded-bl-none border border-stroke py-2 px-[22px] font-semibold text-xs uppercase text-body-color "
               >
               {{ locale.header.title }}
               </span>
                    <h1
                            class="mb-3 text-4xl font-bold leading-[1.208] text-dark sm:text-[42px] lg:text-[30px] xl:text-5xl"
                    >
                        {{ config.first_name }} {{ config.last_name }}
                    </h1>
                    <p class="mb-5 flex items-center text-base font-medium">
                  <span class="text-dark text-lg"> {{ locale.header.title_job }}:
        </span>
                        <span class="pl-3 text-primary text-lg"> {{ config.profession }}
                  </span>
                    </p>
                    <p class="mb-8 max-w-[480px] text-base text-body-color ">
                        {{ locale.header.description }}
                    </p>
                    <ul class="flex flex-wrap items-center">
                        <li>
                            <a
                                    href="mailto:{{ config.email }}"
                                    class="inline-flex items-center justify-center rounded-md bg-primary py-3 px-7 text-center text-base font-medium text-white hover:bg-blue-dark"
                            >
                                {{ locale.header.button_hire }}
                            </a>
                        </li>
                        <li>
                            <a
                                    href="{{ url_for('static', path='files/resume.pdf') }}" download="resume_{{ config.first_name }}_{{ config.last_name }}.pdf"
                                    class="inline-flex items-center justify-center py-3 px-5 text-center text-base font-medium text-[#464646] hover:text-primary"
                            >
                        <span class="mr-2">
                           <svg
                                   width="22"
                                   height="22"
                                   viewBox="0 0 22 22"
                                   fill="none"
                                   xmlns="http://www.w3.org/2000/svg"
                           >
                              <circle cx="11" cy="11" r="11" fill="#3056D3"/>
                              <rect
                                      x="6.90906"
                                      y="13.3636"
                                      width="8.18182"
                                      height="1.63636"
                                      fill="white"
                              />
                              <rect
                                      x="10.1818"
                                      y="6"
                                      width="1.63636"
                                      height="4.09091"
                                      fill="white"
                              />
                              <path
                                      d="M11 12.5454L13.8343 9.47726H8.16576L11 12.5454Z"
                                      fill="white"
                              />
                           </svg>
                        </span>
                                {{ locale.header.button_resume }}
                            </a>
                        </li>
                    </ul>
                    <div class="pt-[50px]">
                        <h6
                                class="mb-5 flex items-center text-xs font-medium text-body-color "
                        >
                            {{ locale.header.title_contact }}
                            <span
                                    class="ml-3 inline-block h-px w-8 bg-body-color "
                            ></span>
                        </h6>
                        <ul class="flex flex-wrap items-center gap-7">
                            {% for social in locale.header.list_social %}
                            <li>
                                <a href="{{ social.link }}" class="text-body-color hover:text-primary">
                                    <img
                                            src="{{ url_for('static', path=social.icon) }}"
                                            alt="{{ social.name }}"
                                            class="w-8"
                                    />


                                </a>
                            </li>
                            {% endfor %}
                        </ul>
                    </div>
                </div>
            </div>
            <div class="hidden px-4 lg:block lg:w-1/12"></div>
            <div class="w-full px-4 lg:w-6/12">
                <div class="lg:ml-auto lg:text-right">
                    <div
                            class="absolute right-0 top-1/2 z-[-1] hidden w-1/2 -translate-y-1/2 lg:block lg:w-full"
                    >
                        <img
                                src="{{ url_for('static', path='files/profile.png') }}"
                                width="600"
                                 height="530"
                                style="margin-right:100px"
                                alt="hero"
                                class="max-w-full lg:ml-auto"
                        />
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- ====== Hero Section End -->